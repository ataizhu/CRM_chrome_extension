{
  "manifest_version": 3,
  "name": "CRM Technologies Tasks",
  "version": "1.0.19",
  "description": "Задачи, статистика, авторизация. CRM Technologies.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "notifications",
    "alarms",
    "idle"
  ],
  "host_permissions": [
    "https://vtiger.crm.kg/*"
  ],
  "action": {
    "default_title": "Открыть задачи",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "CRM Tasks",
    "default_icon": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "crm-tasks@crm.kg",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["authenticationInfo", "personallyIdentifyingInfo"]
      }
    }
  }
}