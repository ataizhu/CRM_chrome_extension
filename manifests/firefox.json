{
  "manifest_version": 3,
  "name": "CRM Technologies Tasks",
  "version": "1.0.13",
  "description": "Задачи, статистика, авторизация. CRM Technologies.",
  "icons": {
    "16": "assets/icon.png",
    "32": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "notifications",
    "alarms",
    "idle"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "Открыть задачи",
    "default_icon": {
      "16": "assets/icon.png",
      "32": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "CRM Tasks",
    "default_icon": "assets/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "crm-tasks@crm.kg",
      "strict_min_version": "128.0"
    }
  }
}
