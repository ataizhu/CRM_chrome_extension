{
  "manifest_version": 3,
  "name": "CRM Technologies Tasks",
  "version": "1.0.16",
  "description": "Задачи, статистика, авторизация. CRM Technologies.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "sidePanel",
    "notifications",
    "alarms",
    "idle"
  ],
  "host_permissions": [
    "https://vtiger.crm.kg/*"
  ],
  "action": {
    "default_title": "Открыть задачи",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}